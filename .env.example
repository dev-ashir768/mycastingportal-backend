# ─── App ────────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ─── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/actor_agency_db?schema=public"

# ─── JWT (Users) ────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=your_user_access_secret_min_64_chars_here
JWT_REFRESH_SECRET=your_user_refresh_secret_min_64_chars_here
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN_MS=604800000

# ─── JWT (Admin) ────────────────────────────────────────────────────────────────
JWT_ADMIN_ACCESS_SECRET=your_admin_access_secret_min_64_chars_here
JWT_ADMIN_REFRESH_SECRET=your_admin_refresh_secret_min_64_chars_here
JWT_ADMIN_ACCESS_EXPIRES_IN=15m
JWT_ADMIN_REFRESH_EXPIRES_IN=1d
JWT_ADMIN_REFRESH_EXPIRES_IN_MS=86400000

# ─── CORS ───────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000

# ─── Client URL (for email links) ───────────────────────────────────────────────
CLIENT_URL=http://localhost:3000

# ─── Email (Gmail SMTP) ─────────────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_gmail_app_password
EMAIL_FROM=your_gmail@gmail.com
EMAIL_FROM_NAME=Actor Agency

# ─── Rate Limiting ──────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
RATE_LIMIT_AUTH_MAX=10

# ─── Security ───────────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MS=900000

# ─── Token Expiry ───────────────────────────────────────────────────────────────
EMAIL_VERIFICATION_EXPIRES_MS=86400000
PASSWORD_RESET_EXPIRES_MS=3600000
